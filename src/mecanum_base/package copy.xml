<?xml version="1.0"?>
<package format="3">
  <name>mecanum_base</name>
  <version>0.1.0</version>

  <description>
    Plugin hardware_interface per una base Mecanum con comunicazione seriale diretta.
    Include nodi di utilità per comandi, odometria e integrazione Nav2.
  </description>

  <maintainer email="tuo.email@example.com">Il Tuo Nome</maintainer>
  <license>Apache-2.0</license>

  <!-- Build system -->
  <buildtool_depend>ament_cmake</buildtool_depend>

  <!-- 
    🔧 Dipendenze usate dal TUO codice C++ 
    (devono essere disponibili sia a build che a runtime)
  -->
  <depend>rclcpp</depend>
  <depend>rclcpp_action</depend>
  <depend>rclcpp_lifecycle</depend>
  <depend>geometry_msgs</depend>
  <depend>nav_msgs</depend>
  <depend>sensor_msgs</depend>
  <depend>std_msgs</depend>
  <depend>tf2_ros</depend>
  <depend>std_srvs</depend>
  <depend>rcl_interfaces</depend>

  <!-- ros2_control + pluginlib (servono a build, export e runtime) -->
  <depend>hardware_interface</depend>
  <depend>pluginlib</depend>
  <depend>controller_manager</depend>
  <depend>ros2_controllers</depend>

  <!-- Per messaggi/servizi custom -->
  <build_depend>rosidl_default_generators</build_depend>
  <exec_depend>rosidl_default_runtime</exec_depend>

  <!-- 
    🚀 Nav2 (solo runtime)
    Manteniamo exec_depend per massima compatibilità con nav2_bringup
  -->
  <exec_depend>nav2_util</exec_depend>
  <exec_depend>nav2_msgs</exec_depend>
  <exec_depend>nav2_common</exec_depend>
  <exec_depend>nav2_bt_navigator</exec_depend>
  <exec_depend>nav2_planner</exec_depend>
  <exec_depend>nav2_controller</exec_depend>
  <exec_depend>nav2_costmap_2d</exec_depend>
  <exec_depend>nav2_map_server</exec_depend>
  <exec_depend>nav2_amcl</exec_depend>
  <exec_depend>nav2_lifecycle_manager</exec_depend>
  <exec_depend>nav2_behaviors</exec_depend>
  <exec_depend>nav2_recoveries</exec_depend>
  <exec_depend>nav2_waypoint_follower</exec_depend>
  <exec_depend>nav2_velocity_smoother</exec_depend>

  <!-- Launch system -->
  <exec_depend>launch</exec_depend>
  <exec_depend>launch_ros</exec_depend>

  <!-- rosbridge (se lo usi davvero) -->
  <exec_depend>rosbridge_server</exec_depend>

  <!-- Gruppo ROSIDL -->
  <member_of_group>rosidl_interface_packages</member_of_group>

  <!-- Plugin ros2_control -->
  <export>
    <build_type>ament_cmake</build_type>
    <pluginlib plugin="${prefix}/share/${PROJECT_NAME}/mecanum_hardware_plugin.xml"/>
  </export>

</package>
